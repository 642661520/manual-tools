{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "composite": false,
    "strict": true,
    "paths": {
      "@/*": ["./src/*"]
    },
  },
  "include": ["vite.config.ts", "uno.config.ts", "server/**/*.ts"]
}
