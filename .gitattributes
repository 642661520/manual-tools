# 自动检测文本文件，统一 LF 行尾符
* text=auto

# 源码文件强制 LF
*.ts text eol=lf
*.js text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Windows 批处理/脚本文件保留 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell 脚本强制 LF
*.sh text eol=lf

# 二进制文件不转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp4 binary
*.mp3 binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar binary
*.gz binary
*.db binary
*.db-wal binary
*.db-shm binary
*.pdf binary
*.lock binary
*.sqlite3 binary
