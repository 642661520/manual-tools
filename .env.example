# JWT 密钥
JWT_SECRET=change-me-in-production

# 数据库路径
DATABASE_PATH=./data/manual.db

# 上传目录
UPLOAD_DIR=./data/uploads

# Y.js 快照配置
YJS_SNAPSHOT_UPDATE_THRESHOLD=500
YJS_SNAPSHOT_INTERVAL_HOURS=24

# 上传限制（MB）
UPLOAD_MAX_SIZE=10
VIDEO_MAX_SIZE=100

# CORS 额外允许的来源域名（逗号分隔，本地开发 localhost:5173 已默认允许）
CORS_ORIGIN=

# PDF 中文字体（可选，默认自动下载 Noto Sans SC）
# 如果服务器无法访问外网，可手动下载字体后配置以下路径
# PDF_FONT_REGULAR=/usr/share/fonts/NotoSansSC-Regular.ttf
# PDF_FONT_BOLD=/usr/share/fonts/NotoSansSC-Bold.ttf

# 飞书应用配置（Bot 通知 + OAuth 绑定）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 飞书 OAuth 回调地址 — 用户扫码后浏览器跳回的地址
# 内网部署时填内网可访问地址（如 http://192.168.1.x:5173/feishu-callback）
# 注意：需在飞书开发者后台「安全设置」中添加此回调 URL
FEISHU_REDIRECT_URI=http://localhost:5173/feishu-callback
# 飞书 API 域名（国际版用 https://open.larksuite.com）
FEISHU_HOST=https://open.feishu.cn

# 本地管理员初始账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 服务端口
PORT=5000

# 日志
# 日志级别：trace / debug / info / warn / error / fatal（开发默认 debug，生产默认 info）
LOG_LEVEL=debug
# 文件日志级别（独立于控制台级别，不设置则跟随 LOG_LEVEL）
LOG_FILE_LEVEL=info
# 日志文件路径（pino-roll 按天轮转，生成 app.2026-06-27.log 格式文件）
LOG_FILE_PATH=./data/logs/app.log
# 日志文件最大大小（MB），超过后立即轮转
LOG_MAX_SIZE_MB=10
# 日志保留天数
LOG_RETAIN_DAYS=30

# AI 辅助写作（OpenAI 兼容接口，可选）
# 支持 OpenAI / DeepSeek / Ollama / 通义千问 等
# 不配置则 AI 功能不可用
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-your-key-here
# AI_MODEL=gpt-4o-mini
