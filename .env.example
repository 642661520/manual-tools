# === 服务 ===
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:5173

# === 安全（生产环境务必修改） ===
JWT_SECRET=change-me-in-production

# === 管理员账号（首次启动自动创建） ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# === 数据库 & 存储（Docker 内路径不用改） ===
DATABASE_PATH=/app/data/manual.db
DB_JOURNAL_MODE=wal
UPLOAD_DIR=/app/data/uploads
EXPORT_DIR=/app/data/exports
IMPORT_DIR=/app/data/imports
CACHE_DIR=/app/data/cache

# === 上传限制（MB） ===
UPLOAD_MAX_SIZE=10
VIDEO_MAX_SIZE=100

# === 日志 ===
# 级别：trace / debug / info / warn / error / fatal
LOG_LEVEL=info
LOG_FILE_LEVEL=info
LOG_FILE_PATH=/app/data/logs/app.log
LOG_HOSTNAME=
LOG_MAX_SIZE_MB=10
LOG_RETAIN_DAYS=30

# === CORS 额外来源（逗号分隔） ===
CORS_ORIGIN=

# === Y.js 协同编辑 ===
YJS_SNAPSHOT_UPDATE_THRESHOLD=500

# === 缓存 ===
REMOTE_CACHE_TTL_DAYS=7
EXPORT_CACHE_TTL_DAYS=30
REMOTE_CACHE_MAX_FILE_MB=50

# === Puppeteer / PDF 导出（Docker 内不用改） ===
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_SKIP_DOWNLOAD=true
# PDF 中文字体（Docker 镜像已含 Noto Sans CJK，无需额外配置）
PDF_FONT_REGULAR=
PDF_FONT_BOLD=

# === 飞书集成（可选，不启用留空） ===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_HOST=https://open.feishu.cn
ADMIN_OPEN_IDS=

# === AI 写作助手（可选，OpenAI 兼容接口） ===
# 支持 OpenAI / DeepSeek / Ollama / 通义千问 等
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# === 默认项目只读（上线后设为 true，仅允许添加成员） ===
DEFAULT_PROJECT_READONLY=false
