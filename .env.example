# === 必填（生产环境务必修改） ===
JWT_SECRET=change-me-in-production

# === 服务端口 ===
PORT=3000

# === 管理员账号（首次启动自动创建） ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# === 数据库 & 存储（Docker 内路径不用改） ===
DATABASE_PATH=/app/data/manual.db
UPLOAD_DIR=/app/data/uploads
EXPORT_DIR=/app/data/exports
IMPORT_DIR=/app/data/imports
CACHE_DIR=/app/data/cache

# === 上传限制（MB） ===
UPLOAD_MAX_SIZE=10
VIDEO_MAX_SIZE=100

# === 日志 ===
# 级别：trace / debug / info / warn / error / fatal
LOG_LEVEL=info
LOG_FILE_LEVEL=info
LOG_FILE_PATH=/app/data/logs/app.log
LOG_MAX_SIZE_MB=10
LOG_RETAIN_DAYS=30

# === CORS 额外来源（逗号分隔） ===
CORS_ORIGIN=

# === Puppeteer / PDF 导出（Docker 内不用改） ===
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_SKIP_DOWNLOAD=true
# PDF 中文字体（Docker 镜像已含 Noto Sans CJK，无需额外配置）
# PDF_FONT_REGULAR=/usr/share/fonts/noto/NotoSansCJK-Regular.ttc
# PDF_FONT_BOLD=/usr/share/fonts/noto/NotoSansCJK-Bold.ttc

# === 飞书集成（可选，不启用留空） ===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=
FEISHU_HOST=https://open.feishu.cn
ADMIN_OPEN_IDS=

# === AI 写作助手（可选，OpenAI 兼容接口） ===
# 支持 OpenAI / DeepSeek / Ollama / 通义千问 等
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-4o-mini
